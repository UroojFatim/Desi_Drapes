# =========================================================================
#  Mahila storefront — environment variables
#  Copy this file to `.env.local` and fill in real values.
#  On Vercel: add each of these in Project → Settings → Environment Variables.
# =========================================================================

# ---- Database (MongoDB Atlas) -------------------------------------------
# Create a free cluster at https://www.mongodb.com/atlas and paste its URI.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tMust?retryWrites=true&w=majority

# ---- Inventory admin login ----------------------------------------------
# Credentials for the /inventory admin area. CHANGE THESE.
INVENTORY_ADMIN_USERNAME=admin
INVENTORY_ADMIN_PASSWORD=change-me
INVENTORY_SESSION_SECRET=replace-with-a-long-random-string

# ---- Virtual Try-On backend (RunPod Serverless) -------------------------
# From your RunPod account: an API key + the serverless endpoint ID that
# runs the IDM-VTON worker (see ../backend/idm_serverless).
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_TRYON_ENDPOINT_ID=xxxxxxxxxxxxxx
